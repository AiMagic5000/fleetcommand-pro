# Cognabase (Supabase) -- FleetCommand database
NEXT_PUBLIC_SUPABASE_URL=https://db.cognabase.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Payment processing -- SMB Inc. platform payments (Stripe)
# Tenants bring their own payment processor (Square, Stripe, etc.) stored per-tenant
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://getfleetcommand.com
NEXT_PUBLIC_APP_NAME=FleetCommand Pro

# Multi-tenant
# Each tenant (trucking company) gets a row in the tenants table
# Their custom domain maps to their tenant_id via middleware
